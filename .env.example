# Environment Variables
# Copy this to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Python API Service (Render.com)
# Setelah deploy ke Render, isi dengan URL service Anda
PYTHON_API_URL=https://cling-python-api.onrender.com
# API secret yang di-generate saat deploy Render (wajib sama dengan di Render env vars)
PYTHON_API_SECRET=your_render_api_secret_here

# Application Settings
NEXT_PUBLIC_APP_NAME=LMS - Learning Management System
NEXT_PUBLIC_APP_URL=http://localhost:3000
